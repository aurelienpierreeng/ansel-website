"{{< slideshow images=\"ansel-0.1-lighttable.jpg,ansel-0.1-import.jpg,ansel-0.1-darkroom.jpg,ansel-0.1-masks.jpg,ansel-0.1-actions.jpg\" >}}\n"
"</div>\n"
