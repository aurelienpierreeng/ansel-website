#: content/news/color-controls-finally-correct/index.md:390
#, no-wrap
msgid "{{< figure src=\"filmic.jpg\" width=\"350\" />}}\n"
msgstr "{{< figure src=\"filmic.jpg\" width=\"350\" />}}\n"

